# Copy this file to ".env" and adjust the values.

# Port the server listens on
PORT=3000

# Public base URL of your site (no trailing slash).
# Used for canonical URLs, the sitemap and robots.txt.
BASE_URL=http://localhost:3000

# Site name shown in the header, footer and titles
SITE_NAME=Calculator Hub

# Admin login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
# For production, generate a bcrypt hash and set ADMIN_PASSWORD_HASH instead of
# ADMIN_PASSWORD (the hash takes priority if both are set):
#   node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
# ADMIN_PASSWORD_HASH=

# Secret used to sign session cookies — set this to a long random string.
SESSION_SECRET=please-change-this-to-a-long-random-string
